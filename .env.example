# Doppelganger Bot Environment Configuration

# === Required ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
LLM_API_KEY=your_api_key_here

# === LLM Provider ===
# Options: openai, anthropic, or any OpenAI-compatible API
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# LLM_API_BASE=https://api.openai.com/v1  # Custom endpoint for compatible APIs
LLM_MAX_TOKENS=300
LLM_TEMPERATURE=0.85

# === Bot Settings ===
DATA_DIR=./data/profiles
MIN_MESSAGES_FOR_PROFILE=20
PROFILE_UPDATE_INTERVAL=10
MAX_VOCAB_SIZE=500
MESSAGE_BATCH_SIZE=50
LOG_LEVEL=INFO

# === Admin ===
# Comma-separated Telegram user IDs with admin privileges
ADMIN_USER_IDS=
