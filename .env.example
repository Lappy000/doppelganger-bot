# Environment Configuration
# Copy this file to .env and fill in your values

# === Telegram ===
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
GROUP_CHAT_ID=-1001234567890

# === LLM Provider ===
# Works with any OpenAI-compatible API (OpenAI, OpenRouter, io.net, Ollama, etc.)
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# === Bot Behavior ===
# Probability of responding to a random message (0.0 to 1.0)
RANDOM_REPLY_CHANCE=0.15

# Minutes of silence before bot initiates conversation
SILENCE_THRESHOLD_MINUTES=120

# Minimum minutes between bot's spontaneous messages
MIN_SPONTANEOUS_INTERVAL=10

# How many messages before triggering profile analysis per user
PROFILE_UPDATE_INTERVAL=10

# Maximum response tokens for LLM
LLM_MAX_TOKENS=1000

# LLM temperature (creativity level, 0.0-2.0)
LLM_TEMPERATURE=0.85

# === Optional ===
# Bot display name in logs (cosmetic)
BOT_NAME=Doppelganger

# Quiet hours (bot won't initiate during these hours, 24h format)
QUIET_HOURS_START=2
QUIET_HOURS_END=9

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
